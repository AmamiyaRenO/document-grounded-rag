# Copy to .env and fill in to enable LLM-based answer generation.
# If unset, the system falls back to a deterministic extractive/template answer,
# so the prototype runs fully offline with no API key.

OPENAI_API_KEY=

# Optional overrides (defaults shown; see hfpef_rag/config.py)
# HFPEF_LLM_MODEL=gpt-4o-mini
# HFPEF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# HFPEF_TOP_K=5
# HFPEF_PRIMARY_THRESHOLD=0.45
# HFPEF_SUPPORT_THRESHOLD=0.35
# HFPEF_MIN_SUPPORTING=2

# Optional LLM answerability check. This runs after similarity retrieval passes
# and before answer generation, when an OpenAI key is configured.
# HFPEF_ANSWERABILITY_CHECK_ENABLED=true
# HFPEF_ANSWERABILITY_MODEL=gpt-4o-mini
# HFPEF_ANSWERABILITY_TEMPERATURE=0
# HFPEF_ANSWERABILITY_MAX_TOKENS=250

# Optional offline semantic safety classifier (requires local Ollama).
# Regex safety checks always run first; if Ollama is unavailable, the classifier
# fails open and the normal RAG flow continues.
# HFPEF_SEMANTIC_GUARDRAIL_ENABLED=true
# HFPEF_OLLAMA_BASE_URL=http://127.0.0.1:11434
# HFPEF_OLLAMA_RISK_MODEL=qwen3:8b
# HFPEF_OLLAMA_TIMEOUT_SECONDS=8
# HFPEF_SEMANTIC_RISK_THRESHOLD=0.75

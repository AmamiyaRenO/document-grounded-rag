# Copy to .env and fill in to enable LLM-based answer generation.
# If unset, the system falls back to a deterministic extractive/template answer,
# so the prototype runs fully offline with no API key.

OPENAI_API_KEY=

# Optional overrides (defaults shown; see src/hfpef_rag/config.py)
# HFPEF_LLM_MODEL=gpt-4o-mini
# HFPEF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# HFPEF_TOP_K=5
# HFPEF_PRIMARY_THRESHOLD=0.45
# HFPEF_SUPPORT_THRESHOLD=0.35
# HFPEF_MIN_SUPPORTING=2
